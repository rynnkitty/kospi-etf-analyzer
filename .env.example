# ==============================================
# KOSPI ETF Sector Analyzer — 환경 변수
# ==============================================

# GitHub Pages 배포 시 서브경로 (레포지토리명과 일치해야 함)
NEXT_PUBLIC_BASE_PATH=/kospi-etf-analyzer

# ---- 아래는 선택 사항 (기본값으로 동작) ----

# 데이터 디렉토리 (기본: public/data)
# DATA_DIR=public/data

# KRX 크롤링 요청 간 딜레이 (초, 기본: 2)
# KRX_REQUEST_DELAY=2

# KRX 크롤링 재시도 횟수 (기본: 3)
# KRX_RETRY_COUNT=3
